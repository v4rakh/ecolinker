  "description": "EcoFlow History dashboard with aggregation support",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "description": "Choose specific days from the 'Days' drop-down. Make sure to at least select the proper time range in Grafana.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 120,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "**Selected Days:** ${day_start}",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.6",
      "title": "Current Selection",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Consumption - Aggregated over selected time period\n\n- Total Consumption = Entire consumption of the household\n- From Solar = Direct use of solar power\n- From Battery = Use of battery\n- From Grid = Use of grid (retrieve)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "fieldMinMax": false,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "kwatth"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 0,
        "y": 2
      },
      "id": 110,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.6",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (attribute) (ecolinker_historical_data{job=\"$job\",device=\"$device\",attribute=~\"To Home|From Battery|From Grid\",start=~\"$day_start\"})",
          "instant": true,
          "legendFormat": "{{attribute}}",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum(ecolinker_historical_data{job=\"$job\",device=\"$device\",attribute=\"To Home\",start=~\"$day_start\"})",
          "format": "time_series",
          "hide": true,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "TOTAL_CON"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(ecolinker_historical_data{job=\"$job\",device=\"$device\",attribute=\"From Battery\",start=~\"$day_start\"})",
          "hide": true,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "FROM_BAT"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(ecolinker_historical_data{job=\"$job\",device=\"$device\",attribute=\"From Grid\",start=~\"$day_start\"})",
          "hide": true,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "FROM_GRID"
        },
        {
          "datasource": {
            "type": "__expr__",
            "uid": "${DS_EXPRESSION}"
          },
          "expression": "$TOTAL_CON-$FROM_BAT-$FROM_GRID",
          "hide": false,
          "refId": "From Solar'",
          "type": "math"
        }
      ],
      "title": "History - Consumption (Aggregated)",
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "To Home",
            "renamePattern": "Total Consumption"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "From Solar'(.*)",
            "renamePattern": "From Solar"
          }
        }
      ],
      "type": "stat"
    },
